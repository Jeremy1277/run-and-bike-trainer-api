# Copie ce fichier en .env pour le développement local.
# Sur Render, ces valeurs vont dans Settings > Environment, jamais dans le code.

STRAVA_CLIENT_ID=ton_client_id
STRAVA_CLIENT_SECRET=ton_client_secret
PORT=3000

# URL du frontend GitHub Pages, utilisée pour la redirection après connexion
FRONTEND_URL=https://jeremy1277.github.io/gravel-trainer

# URL publique de ce backend (utilisée pour construire le redirect_uri Strava)
# En local : http://localhost:3000
# Sur Render : https://gravel-trainer-api.onrender.com
BACKEND_URL=http://localhost:3000

# --- Stockage des tokens / activités ---
# Render efface le disque local à chaque mise en veille du service free tier,
# donc les tokens et activités sont stockés dans un repo GitHub PRIVÉ via l'API
# (même pattern que FlowPilot Studio : fetch SHA -> PUT base64).
#
# GITHUB_STORAGE_TOKEN doit être un Personal Access Token (classic) avec le
# scope "repo" uniquement, généré sur https://github.com/settings/tokens
# Crée d'abord un repo PRIVÉ vide nommé gravel-trainer-data sur GitHub.
GITHUB_STORAGE_TOKEN=ton_github_pat
GITHUB_STORAGE_OWNER=Jeremy1277
GITHUB_STORAGE_REPO=gravel-trainer-data
GITHUB_STORAGE_BRANCH=main
